OPENAI_API_KEY=
# Are.na Personal Access Token (read scope). Optional, but recommended:
# guest tier is 30 req/min and parallel channel fan-out can trip 429.
# Premium tier with a PAT is 300 req/min.
ARENA_TOKEN=

# Owner-mode admin auth for /dev.
# Required together: password verifies login, secret signs the httpOnly cookie.
ARESEARCH_ADMIN_PASSWORD=
ADMIN_COOKIE_SECRET=
